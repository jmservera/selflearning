# selflearning — Environment Variables
# Copy this file to .env and fill in values for your environment.
# In Azure, these are provided via Container Apps environment variables and managed identity.
#
# For local development with Docker Compose (`docker compose up`):
#   - Azure Cosmos DB and Blob Storage are emulated locally (no values needed).
#   - Azure Service Bus and AI Foundry require real Azure resources.
#   - Azure AI Search requires a real Azure resource (or leave blank to disable vector search).

# ─── Azure Subscription (used by azd and Healer for ACA management) ───────────
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=
AZURE_LOCATION=eastus2

# ─── Azure AI Foundry ─────────────────────────────────────────────────────────
# Required for LLM inference (extractor, reasoner, evaluator, orchestrator, healer, api)
AZURE_AI_FOUNDRY_ENDPOINT=
AZURE_AI_FOUNDRY_PROJECT=

# Model names (defaults shown; override if your deployment uses different names)
CHAT_MODEL=gpt-4o
QUESTION_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-large
EXTRACTION_MODEL=gpt-4o-mini
REASONING_MODEL=gpt-4o
EVALUATION_MODEL=gpt-4o

# ─── Azure Cosmos DB ──────────────────────────────────────────────────────────
# When using Docker Compose, Cosmos DB is emulated locally — leave these blank.
# For direct Azure deployment, set AZURE_COSMOS_ENDPOINT to your Cosmos account URL.
AZURE_COSMOS_ENDPOINT=
AZURE_COSMOS_DATABASE=selflearning

# Cosmos DB emulator — docker-compose.yml sets AZURE_COSMOS_ENDPOINT=https://cosmos:8081
# automatically. The emulator's well-known master key is used when services are
# configured to authenticate via account key rather than managed identity:
#   AccountEndpoint=https://cosmos:8081/;AccountKey=C2y6yDjf5/R+ob0N8A7Cgv30VRDJIWEHLM+4QDU5DE2nQ9nDuVTqobD4b5n7QOoRmP4MVTM+5CTVEX0Nz+6tg==;
# Note: The emulator uses a self-signed TLS certificate. Download it from
#   https://localhost:8081/_explorer/emulator.pem and add it to your trust store,
#   or configure the Azure SDK to skip TLS verification for the emulator.
COSMOS_DATABASE_NAME=selflearning

# ─── Azure Service Bus ────────────────────────────────────────────────────────
# No Docker emulator is available for Azure Service Bus.
# Set AZURE_SERVICEBUS_NAMESPACE to your Service Bus namespace (e.g. my-sb.servicebus.windows.net).
# Services will start without it but message-driven pipelines will not function.
AZURE_SERVICEBUS_NAMESPACE=

# Queue and topic names (defaults match docker-compose.yml)
SCRAPER_SERVICEBUS_QUEUE_NAME=scrape-requests
SCRAPER_SERVICEBUS_TOPIC_NAME=scrape-complete
SCRAPE_COMPLETE_TOPIC=scrape-complete
SCRAPE_COMPLETE_SUBSCRIPTION=extractor
EXTRACTION_COMPLETE_TOPIC=extraction-complete
REASONING_REQUESTS_QUEUE=reasoning-requests
REASONING_COMPLETE_TOPIC=reasoning-complete
EVALUATION_COMPLETE_TOPIC=evaluation-complete
ORCHESTRATOR_SUBSCRIPTION_NAME=orchestrator

# ─── Azure Blob Storage ───────────────────────────────────────────────────────
# When using Docker Compose, Azurite emulates Blob Storage — leave AZURE_STORAGE_ACCOUNT blank.
# Azurite uses a well-known development account and key for authentication. Services
# that connect via URL (SCRAPER_BLOB_ACCOUNT_URL / STORAGE_ACCOUNT_URL) must also
# supply the Azurite account key through their SDK connection string or credential:
#   AccountName=devstoreaccount1
#   AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==
# Full connection string (for tools that accept it directly):
#   DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==;BlobEndpoint=http://localhost:10000/devstoreaccount1;QueueEndpoint=http://localhost:10001/devstoreaccount1;
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_CONTAINER=raw-content

# Azurite blob URL used inside docker-compose (auto-configured; override if needed)
AZURITE_BLOB_URL=http://azurite:10000/devstoreaccount1

# ─── Azure AI Search ──────────────────────────────────────────────────────────
# No Docker emulator is available for Azure AI Search.
# Leave blank to disable vector search in the Knowledge service.
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_INDEX_PREFIX=selflearning

# ─── Azure Key Vault ──────────────────────────────────────────────────────────
AZURE_KEYVAULT_NAME=

# ─── Application Insights ─────────────────────────────────────────────────────
# Leave blank to disable telemetry in local development.
APPLICATIONINSIGHTS_CONNECTION_STRING=

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── Local Development ────────────────────────────────────────────────────────
# Set to "true" to signal services that local emulators are in use.
USE_LOCAL_EMULATORS=false
