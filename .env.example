# selflearning — Local Development Environment Variables
# Copy this file to .env and fill in values for local development.
# In Azure, these are provided via Container Apps environment variables and managed identity.

# Azure Subscription
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=
AZURE_LOCATION=eastus2

# Azure AI Foundry
AZURE_AI_FOUNDRY_ENDPOINT=
AZURE_AI_FOUNDRY_PROJECT=

# Azure Cosmos DB
AZURE_COSMOS_ENDPOINT=
AZURE_COSMOS_DATABASE=selflearning

# Azure Service Bus
AZURE_SERVICEBUS_NAMESPACE=

# Azure Storage
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_CONTAINER=raw-content

# Azure AI Search
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_INDEX_PREFIX=selflearning

# Azure Key Vault
AZURE_KEYVAULT_NAME=

# Application Insights
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Local Development (not used in Azure)
# Set to "true" to use local emulators where available
USE_LOCAL_EMULATORS=false
